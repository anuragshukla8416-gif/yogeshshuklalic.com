{
  "name": "yogesh-shukla-advisory-backend",
  "version": "1.2.0",
  "description": "Backend API for the Yogesh Shukla Wealth & Insurance Advisory platform (OTP auth, lead ledger, admin workspace).",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "migrate": "psql \"$DATABASE_URL\" -f db/schema.sql",
    "migrate:up": "node db/migrate.js",
    "seed": "node db/seed.js",
    "cleanup:tokens": "node scripts/purge-revoked-tokens.js",
    "backup": "bash scripts/backup.sh",
    "test": "node --test tests/"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "nodemailer": "^6.9.14",
    "pg": "^8.12.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.4"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
