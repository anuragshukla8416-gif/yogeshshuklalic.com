# ============================================================
# Yogesh Shukla Advisory — Backend Environment Variables
# Copy this file to .env and fill in real values. Never commit .env.
# ============================================================

# Server
PORT=4000
NODE_ENV=development

# Database (PostgreSQL connection string)
DATABASE_URL=postgres://postgres:yash123.@localhost:5432/yogesh_advisory
# Set to true if your Postgres provider requires SSL (Render, Railway, Supabase, RDS, etc.)
PGSSL=false

# Auth
JWT_SECRET=replace_this_with_a_long_random_string
SESSION_TOKEN_EXPIRY=7d
ADMIN_PIN=719900

# CORS — comma-separated list of allowed frontend origins
FRONTEND_ORIGIN=https://yogeshshuklalic.github.io,http://localhost:5500,http://127.0.0.1:5500

# ------------------------------------------------------------
# OTP Delivery — OPTIONAL. Leave blank to run in DEV MODE,
# where OTPs are logged to the server console and returned in
# the API response instead of being sent via SMS/email.
# ------------------------------------------------------------
# SMS (MSG91)
MSG91_AUTH_KEY=548559ABoY8Oh7Q6a4e24f8P1
MSG91_TEMPLATE_ID=

# Email — SMTP (recommended: works with Gmail/Zoho/Yahoo app passwords, or any SMTP relay)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SENDER_EMAIL=noreply@yogeshshuklaadvisory.com

# Email — SendGrid (used only if SMTP_HOST is not set)
SENDGRID_API_KEY=

# ------------------------------------------------------------
# Advisor notifications — email sent to this address whenever
# a new lead comes in (uses the same SMTP/SendGrid config above)
# ------------------------------------------------------------
ADVISOR_EMAIL=yogeshshuklalic@yahoo.com
